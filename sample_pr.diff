@@ -0,0 +1,29 @@
+import pytest
+from unittest.mock import patch, MagicMock
+from app.api.payments import app
+
+@pytest.fixture
+def client():
+    app.config["TESTING"] = True
+    with app.test_client() as c:
+        yield c
+
+def test_charge_missing_fields(client):
+    resp = client.post("/charge", json={})
+    assert resp.status_code == 400
+
+def test_charge_success(client):
+    with patch("app.api.payments.stripe.Charge.create") as mock_charge:
+        mock_charge.return_value = MagicMock(id="ch_123")
+        with patch("app.api.payments.get_connection") as mock_db:
+            mock_db.return_value.cursor.return_value.fetchone.return_value = {
+                "id": 1, "stripe_customer_id": "cus_abc"
+            }
+            resp = client.post("/charge", json={
+                "user_id": 1,
+                "amount": 1000,
+            })
+            assert resp.status_code == 200
+            assert resp.get_json()["status"] == "ok"
+
+def test_history(client):
+    resp = client.get("/history?user_id=1")
+    assert resp.status_code == 200
